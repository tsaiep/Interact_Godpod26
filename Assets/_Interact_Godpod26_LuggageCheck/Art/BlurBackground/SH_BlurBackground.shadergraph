    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "8ac4d3ea1a564fe4a50dd99a0951b1bd",
    "m_Title": "",
    "m_Content": "In order to create the blur, the scene must be sampled multiple times and averaged. In order to keep performance decent, be sure that BlurCycles and BlurSamplesPerCycle are low values.",
